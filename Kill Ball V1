-- SERVIÇOS
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local lp = Players.LocalPlayer
local character = lp.Character or lp.CharacterAdded:Wait()

-- 1. CRIAÇÃO DA TOOL DE CONTROLE (INVISÍVEL E SEM ANIMAÇÃO)
local tool = Instance.new("Tool")
tool.Name = " FLING BALL "
tool.RequiresHandle = false
tool.Parent = lp:WaitForChild("Backpack")

-- Suporte para detectar cliques em qualquer distância/visão
local camera = Workspace.CurrentCamera

-- 2. FUNÇÃO DE ATAQUE SINCRONIZADA EM 999999
local function executarAtaqueLimitado(alvoPlayer)
	local alvoChar = alvoPlayer.Character
	if not alvoChar or not alvoChar:FindFirstChild("HumanoidRootPart") then return end
	
	local alvoHRP = alvoChar.HumanoidRootPart
	local alvoHum = alvoChar.Humanoid
	local vCharacter = lp.Character

	-- --- AUTOMAÇÃO DO LANÇAMENTO ---
	local remote = ReplicatedStorage:WaitForChild("RE"):WaitForChild("1Too1l")  

	if not lp.Backpack:FindFirstChild("SoccerBall") and not character:FindFirstChild("SoccerBall") then
		remote:InvokeServer("PickingTools", "SoccerBall")
	end  

	repeat task.wait() until lp.Backpack:FindFirstChild("SoccerBall") or character:FindFirstChild("SoccerBall")  

	local sTool = lp.Backpack:FindFirstChild("SoccerBall") or character:FindFirstChild("SoccerBall")
	sTool.Parent = character  

	local ballName = "Soccer" .. lp.Name
	local ballFolder = Workspace:WaitForChild("WorkspaceCom"):WaitForChild("001_SoccerBalls")

	local bolaFisica = nil

	repeat task.wait() until ballFolder:FindFirstChild(ballName)
	bolaFisica = ballFolder:FindFirstChild(ballName)  

	sTool.Parent = lp.Backpack  

	if bolaFisica then
		local nc = Instance.new("NoCollisionConstraint", bolaFisica)
		nc.Part0 = bolaFisica
		nc.Part1 = vCharacter:FindFirstChild("HumanoidRootPart") or vCharacter:FindFirstChild("Head")

		bolaFisica.CanCollide = true
		bolaFisica.Massless = false

		-- Friction ajustado para 2 (máximo permitido)
		bolaFisica.CustomPhysicalProperties = PhysicalProperties.new(100, 2, 0, 100, 100)

		local velocity = Instance.new("BodyVelocity")
		velocity.Name = "FlingPower"
		velocity.Velocity = Vector3.new(99999, 99999, 99999)
		velocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
		velocity.P = 999999
		velocity.Parent = bolaFisica  

		local partesAlvo = {"Head", "UpperTorso", "LowerTorso"}

		task.spawn(function()
			local index = 1
			while bolaFisica and bolaFisica.Parent and alvoHum.Health > 0 do
				local nomeParte = partesAlvo[index]
				local p = alvoChar:FindFirstChild(nomeParte)

				if p then
					bolaFisica.CFrame = CFrame.new(p.Position + (p.Velocity / 1.5))  

					bolaFisica.Velocity = Vector3.new(999999, 999999, 999999)
					bolaFisica.RotVelocity = Vector3.new(99999, 99999, 99999)
					bolaFisica.Orientation += Vector3.new(45, 60, 30)
				end  

				task.wait(1/6000)

				index = index + 1
				if index > #partesAlvo then index = 1 end
			end

			if bolaFisica then
				bolaFisica:Destroy()
			end
		end)
	end
end

-- 3. CONEXÃO DE CLIQUE COM ALCANCE INFINITO (ADAPTADO PARA VIEW)
local mouse = lp:GetMouse()

tool.Activated:Connect(function()
	-- Técnica de Raycast para ignorar a distância do personagem real
	-- Ele pega a posição do mouse na tela e projeta um raio a partir da câmera atual (mesmo em VIEW)
	local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
	raycastParams.FilterDescendantsInstances = {character} -- Ignora você mesmo
	
	-- Raio com alcance de 50.000 studs (Infinito na prática)
	local raycastResult = Workspace:Raycast(unitRay.Origin, unitRay.Direction * 50000, raycastParams)

	if raycastResult and raycastResult.Instance then
		local hitPart = raycastResult.Instance
		local model = hitPart:FindFirstAncestorOfClass("Model")
		
		if model and model:FindFirstChild("Humanoid") then
			local tPlayer = Players:GetPlayerFromCharacter(model)
			
			if tPlayer and tPlayer ~= lp then
				executarAtaqueLimitado(tPlayer)
			end
		end
	end
end)

